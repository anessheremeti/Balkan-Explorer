# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Base URL of the Express backend (change to your deployed backend URL in production)
VITE_API_URL=http://localhost:3001

# Google Maps JavaScript API key — enable Maps JavaScript API + Places API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Supabase project credentials (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key
