# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# CORS — set to your frontend URL in production (e.g. https://yourapp.netlify.app)
FRONTEND_URL=http://localhost:5173

# Supabase — use the SERVICE ROLE key here (server-side only, never expose to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI (OpenRouter) — used for itinerary theme generation
# Free models available at https://openrouter.ai/models
OPENROUTER_API_KEY=your_openrouter_api_key

# Photo providers — all optional; the server falls back gracefully if keys are missing
PEXELS_API_KEY=your_pexels_api_key          # https://www.pexels.com/api/
PIXABAY_API_KEY=your_pixabay_api_key         # https://pixabay.com/api/docs/
UNSPLASH_ACCESS_KEY=your_unsplash_access_key # https://unsplash.com/developers

# Place data (optional — Overpass is used first and requires no key)
OPENTRIPMAP_API_KEY=your_opentripmap_api_key # https://opentripmap.io/
